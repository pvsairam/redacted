# Server environment variables
# Copy this file to .env and fill in your values

# Database connection string (SQLite by default)
DATABASE_URL="file:./dev.db"

# Server port
PORT=3001

# CORS origin (web app URL)
CORS_ORIGIN="http://localhost:3000"

# Absolute path where run artifacts (screenshots, videos) will be stored
# Use a path outside the project for persistence
RUNS_STORAGE_PATH="./runs"

# Default platform settings (overridden by database settings)
DEFAULT_BROWSER="chromium"
DEFAULT_HEADLESS="true"
DEFAULT_STEP_TIMEOUT_MS="10000"
DEFAULT_CAPTURE_SCREENSHOTS="true"
DEFAULT_RECORD_VIDEO="true"
DEFAULT_SAVE_TRACES="false"
DEFAULT_REPORT_AUTHOR="Automation Team"
DEFAULT_REPORT_COMPANY=""
