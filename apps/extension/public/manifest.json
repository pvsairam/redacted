{
  "manifest_version": 3,
  "name": "[REDACTED] Automation Recorder",
  "version": "0.1.0",
  "description": "Record browser interactions and replay them reliably. Private Beta.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "[REDACTED] - Automation Recorder"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:3001/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["chunks/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
