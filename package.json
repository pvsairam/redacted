{
  "name": "qa-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Browser Test Automation Platform - Private Beta",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "db:push": "pnpm --filter @qa-platform/server prisma:push",
    "db:migrate": "pnpm --filter @qa-platform/server prisma:migrate",
    "db:studio": "pnpm --filter @qa-platform/server prisma:studio",
    "db:generate": "pnpm --filter @qa-platform/server prisma:generate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint-config-prettier": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.4"
}
